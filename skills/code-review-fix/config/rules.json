{
  "version": "1.0.0",
  "rules": {
    "security": {
      "enabled": true,
      "checkEval": true,
      "checkInnerHTML": true,
      "checkConsoleSensitive": true,
      "checkSQLInjection": true
    },
    "style": {
      "enabled": true,
      "checkVar": true,
      "checkSemicolon": false,
      "checkNaming": true,
      "maxLineLength": 120
    },
    "performance": {
      "enabled": true,
      "checkDOMInLoop": true,
      "checkUnusedImports": true
    }
  },
  "languages": {
    "javascript": true,
    "typescript": true,
    "python": true,
    "go": false
  }
}
